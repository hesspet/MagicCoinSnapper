@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        MagicCoinSnapper
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Sm" Elevation="1">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">MagicCoinSnapper</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All">Startseite</MudNavLink>
            <MudNavLink Href="/camera" Match="NavLinkMatch.Prefix">Scan</MudNavLink>
            <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix">Einstellungen</MudNavLink>
            <MudNavLink Href="/ueber" Match="NavLinkMatch.Prefix">Über</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
