@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="Settings.IsDarkDesign" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="mcs-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" aria-label="Navigation oeffnen" />
        <MudText Typo="Typo.subtitle1" Class="mcs-app-title">MagicCoinSnapper</MudText>
        <MudSpacer />
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" Size="Size.Small" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Sm" Elevation="0" Class="mcs-drawer">
        <MudDrawerHeader>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">MagicCoinSnapper</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Smartphone-Scan</MudText>
            </MudStack>
        </MudDrawerHeader>
        <MudNavMenu Class="mcs-nav-menu">
            <MudNavLink Href="." Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Startseite</MudNavLink>
            <MudNavLink Href="camera" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PhotoCamera">Scan</MudNavLink>
            @if (Settings.ExpertModeEnabled)
            {
                <MudNavLink Href="collection" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Collections">Bildersammlung</MudNavLink>
            }
            <MudNavLink Href="settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">Einstellungen</MudNavLink>
            <MudNavLink Href="ueber" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Info">Über</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="mcs-main-content">
        <div class="mcs-page-host">
            @Body
        </div>
    </MudMainContent>

    <div class="mcs-bottom-action" role="navigation" aria-label="Schnellaktion">
        <MudButton Href="camera" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoCamera" Class="mcs-bottom-button">
            Scan starten
        </MudButton>
    </div>
</MudLayout>

@code {
    [Inject] AppSettingsService Settings { get; set; } = default!;

    private bool _drawerOpen = false;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#d8a83f",
            PrimaryContrastText = "#120f08",
            Secondary = "#b8b2a7",
            Tertiary = "#7c4dff",
            Background = "#07070a",
            Surface = "#171720",
            AppbarBackground = "#101016",
            AppbarText = "#f5f1e8",
            DrawerBackground = "#171720",
            DrawerText = "#f5f1e8",
            DrawerIcon = "#d8a83f",
            TextPrimary = "#f5f1e8",
            TextSecondary = "#b8b2a7",
            ActionDefault = "#d8a83f",
            LinesDefault = "#343442",
            Divider = "#343442",
            Error = "#ff5a5f",
            Success = "#49d17d",
            Warning = "#f2c35b",
            Info = "#64b5f6"
        },
        PaletteLight = new PaletteLight
        {
            Primary = "#9a6d13",
            PrimaryContrastText = "#fff9ef",
            Secondary = "#635b4e",
            Tertiary = "#6b4fe8",
            Background = "#f6f1e8",
            Surface = "#fff9ef",
            AppbarBackground = "#efe5d5",
            AppbarText = "#211b12",
            DrawerBackground = "#fff9ef",
            DrawerText = "#211b12",
            DrawerIcon = "#9a6d13",
            TextPrimary = "#211b12",
            TextSecondary = "#635b4e",
            ActionDefault = "#9a6d13",
            LinesDefault = "#d7cbb8",
            Divider = "#d7cbb8",
            Error = "#b3261e",
            Success = "#247a45",
            Warning = "#9a6d13",
            Info = "#1e6aa8"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "14px"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        Settings.OnChanged += OnSettingsChanged;
        await Settings.LoadAsync();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Settings.OnChanged -= OnSettingsChanged;
    }
}
