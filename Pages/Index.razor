@page "/"
<PageTitle>Startseite</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mcs-page">
    <MudStack Spacing="4">
        <MudPaper Elevation="0" Class="mcs-hero-panel">
            <MudStack Spacing="3">
                <MudText Class="mcs-kicker">Smartphone-Scan</MudText>
                <h1 class="mcs-page-title">Münze fotografieren. Bild vorbereiten. Scan starten.</h1>
                <MudText Class="mcs-lead">
                    MagicCoinSnapper ist für den schnellen Smartphone-Einsatz gedacht: Kamera öffnen, Hand mit Münze aufnehmen oder ein Bild laden.
                </MudText>
                <MudButton Href="camera" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoCamera" Class="mcs-wide-button">
                    Scan starten
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="mcs-panel">
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle1">Aktueller Stand</MudText>
                <div class="mcs-status-row">
                    <div class="mcs-status-card">
                        <MudText Typo="Typo.subtitle2">Kamera und Upload</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Bereit fuer Aufnahme, Vorschau und Speichern.</MudText>
                    </div>
                    <div class="mcs-status-card">
                        <MudText Typo="Typo.subtitle2">Münzerkennung</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">ONNX-Pipeline vorbereitet, mit Heuristik-Fallback bis zum trainierten Modell.</MudText>
                    </div>
                    <div class="mcs-status-card">
                        <MudText Typo="Typo.subtitle2">Bildersammlung</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Im Expertenmodus Rohbilder sammeln und als ZIP fuer den Desktop-Trainer exportieren.</MudText>
                    </div>
                </div>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>
