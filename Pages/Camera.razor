@page "/camera"
<PageTitle>Scan</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="camera-page">
    <MudStack Spacing="1" Class="camera-header">
        <h1>Scan</h1>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Münze in die Hand legen, Bild aufnehmen oder aus der Galerie laden.
        </MudText>
        @if (!string.IsNullOrWhiteSpace(_activeModelStatus))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_activeModelStatus</MudText>
        }
    </MudStack>

    <MudPaper Elevation="0" Class="camera-stage">
        <video id="@_videoId" class="camera-video @(_livePreview ? "" : "hidden")" playsinline autoplay muted></video>

        @if (_hasImage && !_livePreview)
        {
            <MudImage Src="@(_hasCoinImage ? _coinPreviewUrl : _previewUrl)" Fluid="true" ObjectFit="ObjectFit.Contain" Alt="@(_hasCoinImage ? "Freigestellte Münze" : "Aufgenommenes Bild")" Class="@PreviewImageClass" />
        }

        @if (!_livePreview && !_hasImage)
        {
            <div class="camera-empty">
                <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1">Bereit für ein Bild</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Starte die Kamera oder lade ein vorhandenes Foto.
                </MudText>
            </div>
        }

        @if (_livePreview)
        {
            <div class="camera-overlay">
                Hand ruhig halten. Münze sichtbar platzieren.
            </div>
        }

        @if (_hasImage && !_livePreview && !string.IsNullOrWhiteSpace(_scanStatus))
        {
            <div class="camera-overlay">
                @_scanStatus
            </div>
        }
    </MudPaper>

    @if (_visibleQualityIssue is not null)
    {
        <div class="camera-quality-issue" role="alert">
            <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Size="Size.Small" />
            <MudText Typo="Typo.body2">@_visibleQualityIssue.Message</MudText>
        </div>
    }

    <MudPaper Elevation="0" Class="camera-actions">
        @if (_livePreview)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCapture" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.Camera">
                Foto aufnehmen
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="OnCameraStop" Disabled="@(!_livePreview)" FullWidth="true">
                Kamera stoppen
            </MudButton>
        }
        else if (_hasImage)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnScan" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.AutoAwesome">
                @(_hasCoinImage ? "Erneut scannen" : "Bild scannen")
            </MudButton>
            <MudStack Row="true" Spacing="2" Class="camera-action-row">
                <MudButton Variant="Variant.Outlined" OnClick="OnSave" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.Download">
                    @(_hasCoinImage ? "Münze speichern" : "Speichern")
                </MudButton>
                <MudFileUpload T="IBrowserFile" Files="_uploadedFile" FilesChanged="@((IBrowserFile? f) => OnFileSelected(f))" Accept="image/png,image/jpeg" MaxFileSize="10485760" Class="camera-upload">
                    <CustomContent Context="uploader">
                        <MudButton Variant="Variant.Outlined" OnClick="@(() => uploader.OpenFilePickerAsync())" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoLibrary">
                            Ersetzen
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
            </MudStack>
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="OnClear" FullWidth="true" StartIcon="@Icons.Material.Filled.Delete">
                Bild löschen
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCameraStart" Disabled="@(_livePreview || _isBusy)" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoCamera">
                Kamera starten
            </MudButton>
            <MudFileUpload T="IBrowserFile" Files="_uploadedFile" FilesChanged="@((IBrowserFile? f) => OnFileSelected(f))" Accept="image/png,image/jpeg" MaxFileSize="10485760">
                <CustomContent Context="uploader">
                    <MudButton Variant="Variant.Outlined" OnClick="@(() => uploader.OpenFilePickerAsync())" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoLibrary">
                        Bild aus Galerie laden
                    </MudButton>
                </CustomContent>
            </MudFileUpload>
        }
    </MudPaper>

    @if (_scanDebugMode && _scanDebugInfo is not null)
    {
        <MudPaper Elevation="0" Class="camera-debug-panel">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.subtitle1">Scan-Debug</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        ONNX: @(_scanDebugInfo.UsedOnnx ? "verwendet" : "nicht verwendet")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Modell: @FormatModel(_scanDebugInfo)</MudText>
                    @if (!string.IsNullOrWhiteSpace(_scanDebugInfo.ModelPath))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pfad: @_scanDebugInfo.ModelPath</MudText>
                    }
                    @if (!string.IsNullOrWhiteSpace(_scanDebugInfo.ModelUrl))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">URL: @_scanDebugInfo.ModelUrl</MudText>
                    }
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Schwelle: @FormatNumber(_scanDebugInfo.Threshold)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Konfidenz: @FormatNumber(_scanDebugInfo.Confidence)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Maske: @_scanDebugInfo.MaskPixelCount Pixel (@FormatPercent(_scanDebugInfo.MaskCoverage))</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Finalmaske: @_scanDebugInfo.FinalMaskMode</MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_scanDebugInfo.FallbackReason))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Fallback: @_scanDebugInfo.FallbackReason
                    </MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(_scanDebugInfo.OnnxError))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                        ONNX-Fehler: @_scanDebugInfo.OnnxError
                    </MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(_maskPreviewUrl))
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2">Masken-Vorschau</MudText>
                        <MudImage Src="@_maskPreviewUrl" Fluid="true" ObjectFit="ObjectFit.Contain" Alt="Debug-Vorschau der Segmentierungsmaske" Class="camera-debug-mask" />
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] ImageStateService ImageState { get; set; } = default!;
    [Inject] AppSettingsService Settings { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    private bool _livePreview;
    private bool _isBusy;
    private bool _hasImage;
    private bool _hasCoinImage;
    private bool _scanDebugMode;
    private string? _previewUrl;
    private string? _coinPreviewUrl;
    private string? _maskPreviewUrl;
    private string? _scanStatus;
    private string? _activeModelStatus;
    private ScanQualityIssue? _visibleQualityIssue;
    private CoinExtractionDebugInfo? _scanDebugInfo;
    private IBrowserFile? _uploadedFile;
    private IJSObjectReference? _module;
    private const string _videoId = "cam";
    private string PreviewImageClass => _hasCoinImage ? "preview-image coin-result-image" : "preview-image";

    protected override async Task OnInitializedAsync()
    {
        await Settings.LoadAsync();
        _scanDebugMode = Settings.ScanDebugModeEnabled;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Pages/Camera.razor.js");
            var activeModelName = await _module.InvokeAsync<string?>("getActiveModelName");
            _activeModelStatus = string.IsNullOrWhiteSpace(activeModelName) ? "Scan-Modell: Heuristik" : $"Scan-Modell: {activeModelName}";
            StateHasChanged();
        }
    }

    private async Task OnCameraStart()
    {
        if (_isBusy || _livePreview) return;
        _isBusy = true;
        try
        {
            await _module!.InvokeVoidAsync("init", _videoId);
            _livePreview = true;
        }
        catch (JSException ex)
        {
            ShowCameraError(ex);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task OnCameraStop()
    {
        await StopCameraAsync();
        _livePreview = false;
    }

    private async Task OnCapture()
    {
        try
        {
            var dataUrl = await _module!.InvokeAsync<string>("capture");
            var bytes = Convert.FromBase64String(dataUrl.Substring(dataUrl.IndexOf(',') + 1));
            SetPreview(bytes, "image/png", "camera");
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Aufnahme fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        await StopCameraAsync();
        _livePreview = false;
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null) return;
        _uploadedFile = file;
        try
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();
            SetPreview(bytes, file.ContentType, "upload");
        }
        catch (IOException ex)
        {
            Snackbar.Add($"Datei zu groß oder ungültig: {ex.Message}", Severity.Error);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add($"Datei zu groß oder ungültig: {ex.Message}", Severity.Error);
        }
    }

    private void SetPreview(byte[] bytes, string contentType, string source)
    {
        _previewUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
        _hasImage = true;
        _hasCoinImage = false;
        _coinPreviewUrl = null;
        _maskPreviewUrl = null;
        _scanDebugInfo = null;
        _scanStatus = null;
        _visibleQualityIssue = null;
        ImageState.SetImage(bytes, contentType, source);
    }

    private async Task OnSave()
    {
        if (!_hasImage) return;
        var bytes = _hasCoinImage && ImageState.ExtractedImageBytes is not null
            ? ImageState.ExtractedImageBytes
            : ImageState.ImageBytes!;
        var contentType = _hasCoinImage && !string.IsNullOrWhiteSpace(ImageState.ExtractedContentType)
            ? ImageState.ExtractedContentType!
            : ImageState.ContentType!;
        var filename = _hasCoinImage ? "magiccoinsnapper-coin.png" : contentType == "image/png" ? "magiccoinsnapper.png" : "magiccoinsnapper.jpg";
        var ms = new MemoryStream(bytes);
        var streamRef = new DotNetStreamReference(ms);
        try
        {
            await _module!.InvokeVoidAsync("downloadFromStream", streamRef, filename, contentType);
        }
        finally
        {
            await ms.DisposeAsync();
        }
    }

    private void OnClear()
    {
        _previewUrl = null;
        _coinPreviewUrl = null;
        _maskPreviewUrl = null;
        _scanDebugInfo = null;
        _scanStatus = null;
        _visibleQualityIssue = null;
        _hasImage = false;
        _hasCoinImage = false;
        _uploadedFile = null;
        ImageState.Clear();
    }

    private async Task OnScan()
    {
        if (!_hasImage || string.IsNullOrWhiteSpace(_previewUrl) || _module is null) return;

        _isBusy = true;
        _scanStatus = "Scan läuft";
        _visibleQualityIssue = null;
        try
        {
            var result = await _module.InvokeAsync<CoinExtractionResult>("extractCoin", _previewUrl, _scanDebugMode);
            var bytes = GetBytesFromDataUrl(result.DataUrl);
            _coinPreviewUrl = result.DataUrl;
            _hasCoinImage = true;
            _scanDebugInfo = _scanDebugMode ? result.Debug : null;
            _maskPreviewUrl = _scanDebugInfo?.MaskPreviewDataUrl;
            _visibleQualityIssue = GetVisibleQualityIssue(result.QualityIssues);
            _scanStatus = result.UsedOnnx && !string.IsNullOrWhiteSpace(result.ModelDisplayName) ? $"Münze erkannt: {result.ModelDisplayName}" : result.UsedOnnx ? "Münze erkannt" : "Heuristik-Ergebnis";
            ImageState.SetExtractedImage(bytes, "image/png");
            Snackbar.Add(result.Message ?? "Münze freigestellt.", result.UsedOnnx ? Severity.Success : Severity.Info);
        }
        catch (JSException ex)
        {
            _scanStatus = "Scan fehlgeschlagen";
            Snackbar.Add($"Scan fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static byte[] GetBytesFromDataUrl(string dataUrl)
    {
        var comma = dataUrl.IndexOf(',');
        return Convert.FromBase64String(dataUrl[(comma + 1)..]);
    }

    private static string FormatModel(CoinExtractionDebugInfo debug)
    {
        if (!string.IsNullOrWhiteSpace(debug.ModelDisplayName) && !string.IsNullOrWhiteSpace(debug.ModelId))
        {
            return $"{debug.ModelDisplayName} ({debug.ModelId})";
        }

        return debug.ModelDisplayName ?? debug.ModelId ?? "kein Modell";
    }

    private static string FormatNumber(double? value)
    {
        return value is double number ? number.ToString("0.###") : "-";
    }

    private static string FormatPercent(double? value)
    {
        return value is double number ? $"{(number * 100).ToString("0.0")} %" : "-";
    }

    private static ScanQualityIssue? GetVisibleQualityIssue(ScanQualityIssue[]? qualityIssues)
    {
        if (qualityIssues is null) return null;

        foreach (var issue in qualityIssues)
        {
            if (string.IsNullOrWhiteSpace(issue.Message)) continue;
            if (string.Equals(issue.Severity, "Warning", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(issue.Severity, "Error", StringComparison.OrdinalIgnoreCase))
            {
                return issue;
            }
        }

        return null;
    }

    private void ShowCameraError(JSException ex)
    {
        var msg = ex.Message;
        if (msg.Contains("NotAllowed"))
        {
            msg = "Kamerazugriff verweigert. Bitte Berechtigung prüfen.";
        }
        else if (msg.Contains("NotFound"))
        {
            msg = "Keine Kamera gefunden.";
        }
        Snackbar.Add(msg, Severity.Error);
    }

    private async Task StopCameraAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); }
            catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopCameraAsync();
        if (_module is not null)
        {
            await _module.DisposeAsync();
            _module = null;
        }
    }

    private sealed record CoinExtractionResult(string DataUrl, bool UsedOnnx, double Confidence, int Width, int Height, string? Message, string? ModelDisplayName, CoinExtractionDebugInfo? Debug, ScanQualityIssue[]? QualityIssues);

    private sealed record ScanQualityIssue(string Code, string Severity, string Message);

    private sealed record CoinExtractionDebugInfo(
        bool UsedOnnx,
        string? ModelId,
        string? ModelDisplayName,
        string? ModelPath,
        string? ModelUrl,
        double? Threshold,
        double? Confidence,
        int MaskPixelCount,
        double? MaskCoverage,
        string? FinalMaskMode,
        string? OnnxError,
        string? FallbackReason,
        string? MaskPreviewDataUrl);
}
