@page "/camera"
@inject IJSRuntime JS

<h3>MagicCoinSnapper – Live Kamera v5</h3>

<video @ref="videoRef" autoplay playsinline style="width: 100%; max-height: 50vh; border: 1px solid #ccc;"></video>
<canvas @ref="canvasRef" style="display: none;"></canvas>

<div style="margin-top: 1rem;">
    <p>b1</p>
    <button @onclick="StartCamera">Kamera starten</button>

    <p>b2</p>
    <button @onclick="TakeSnapshot">Foto aufnehmen</button>

    <p style="margin-top: 1rem; color: darkslategray;">
        <em>@status</em>
    </p>
    <h4>Status-Ausgaben:</h4>
    <ul style="background: #f8f8f8; border: 1px solid #ccc; padding: 0.5rem; font-family: monospace; font-size: 0.9em; max-height: 200px; overflow-y: auto;">
        @foreach (var log in jsLog)
        {
            <li>@log</li>
        }
    </ul>
</div>

@if (!string.IsNullOrEmpty(snapshotData))
{
    <h4>Aufgenommenes Bild:</h4>
    <img src="@snapshotData" style="max-width: 100%;" />

    <h4>Freigestellte Münze:</h4>
    <canvas id="resultCanvas" width="512" height="512" style="border:1px solid #ccc; background: white;"></canvas>
}

@code {
    private ElementReference videoRef;
    private ElementReference canvasRef;
    private string? snapshotData;
    private string status = "";
    private List<string> jsLog = new();


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {


            try
            {


                bool openCvReady = await JS.InvokeAsync<bool>("waitForOpenCv");
                if (openCvReady)
                {
                    AddLog("✅ OpenCV.js ist bereit.");
                }
                else
                {
                    AddLog("❌ OpenCV.js konnte nicht initialisiert werden.");
                }
            }
            catch (Exception ex)
            {
                AddLog("❌ Fehler beim Laden von coinProcessor.js oder beim OpenCV-Warten: " + ex.Message);
            }

            StateHasChanged();
        }
    }


    private async Task StartCamera()

    {
        try
        {
            await JS.InvokeVoidAsync("startCamera", videoRef);
            AddLog("✅ Kamera-Start erfolgreich (JS-Funktion lief durch)");
        }
        catch (Exception ex)
        {
            AddLog("❌ Fehler beim Start der Kamera: " + ex.Message);
        }
        StateHasChanged();

    }

    private async Task TakeSnapshot()
    {

        AddLog("▶️ TakeSnapshot()");
        try
        {
            snapshotData = await JS.InvokeAsync<string>("captureSnapshot", videoRef, canvasRef);
            if (!string.IsNullOrEmpty(snapshotData))
                AddLog("✅ Snapshot aufgenommen.");
            else
                AddLog("⚠️ Snapshot fehlgeschlagen – leerer DataURL.");
        }
        catch (Exception ex)
        {
            AddLog("❌ Fehler beim Snapshot: " + ex.Message);
        }

        try
        {
            await JS.InvokeVoidAsync("extractCoinFromImage", snapshotData, "resultCanvas");
            AddLog("✅ Münze extrahiert und angezeigt.");
        }
        catch (Exception ex)
        {
            AddLog($"❌ Fehler bei Extraktion: {ex.Message}");
        }
        StateHasChanged();

    }

    private void AddLog(string message)
    {
        jsLog.Insert(0, $"{DateTime.Now:HH:mm:ss} - {message}");
        if (jsLog.Count > 50)
        {
            jsLog.RemoveAt(jsLog.Count - 1);
        }
    }
}
