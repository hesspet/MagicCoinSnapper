@page "/collection"
@implements IDisposable

<PageTitle>Bildersammlung</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="collection-page">
    <MudStack Spacing="4">
        <MudStack Spacing="1" Class="collection-header">
            <h1>Bildersammlung</h1>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Rohbilder fuer das Desktop-Training sammeln und als ZIP exportieren.
            </MudText>
        </MudStack>

        @if (!AppSettings.ExpertModeEnabled)
        {
            <MudPaper Elevation="0" Class="collection-panel">
                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1">Expertenmodus ist aus</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Aktiviere den Expertenmodus in den Einstellungen, um Rohbilder fuer Trainingsdaten zu sammeln.
                    </MudText>
                    <MudButton Href="/settings" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="collection-primary-button">
                        Einstellungen oeffnen
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="collection-stage">
                @if (_hasImage)
                {
                    <MudImage Src="@_previewUrl" Fluid="true" ObjectFit="ObjectFit.Contain" Alt="Rohbild fuer Training" Class="collection-preview" />
                    <div class="collection-stage-badge">@_stageMessage</div>
                }
                else
                {
                    <div class="collection-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Collections" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">Kein Rohbild gewaehlt</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            Verwende ein aktuelles Scanbild oder lade ein Bild aus der Galerie.
                        </MudText>
                    </div>
                }
            </MudPaper>

            <MudPaper Elevation="0" Class="collection-panel">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.subtitle2">Bildquelle</MudText>
                    <MudStack Row="true" Spacing="2" Class="collection-action-row">
                        <MudButton Href="/camera" Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoCamera">
                            Bild aufnehmen
                        </MudButton>
                        <MudFileUpload T="IBrowserFile" Files="_uploadedFile" FilesChanged="@((IBrowserFile? f) => OnFileSelected(f))" Accept="image/png,image/jpeg" MaxFileSize="10485760" Class="collection-upload">
                            <CustomContent Context="uploader">
                                <MudButton Variant="Variant.Outlined" OnClick="@(() => uploader.OpenFilePickerAsync())" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoLibrary">
                                    Bild laden
                                </MudButton>
                            </CustomContent>
                        </MudFileUpload>
                    </MudStack>

                    @if (ImageState.HasImage)
                    {
                        <MudButton Variant="Variant.Outlined" OnClick="UseCurrentImage" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.AddPhotoAlternate">
                            Aktuelles Scanbild verwenden
                        </MudButton>
                    }

                    <MudTextField @bind-Value="_notes" Label="Notiz optional" Lines="2" Variant="Variant.Outlined" Placeholder="z. B. Silberdollar, Buehnenlicht, Sharpie sichtbar" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveImageAsync" Disabled="@(!_hasImage || _isBusy)" FullWidth="true" StartIcon="@Icons.Material.Filled.Save" Class="collection-primary-button">
                        Rohbild speichern
                    </MudButton>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="collection-panel">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.subtitle2">Gesammelte Rohbilder</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_sampleCount Bilder liegen lokal im Browser. Der ZIP-Export landet im Download-/Dateien-Bereich Deines Smartphones.
                    </MudText>
                    <MudButton Variant="Variant.Outlined" OnClick="ExportAsync" Disabled="@(_sampleCount == 0 || _isBusy)" FullWidth="true" StartIcon="@Icons.Material.Filled.Archive">
                        Raw-ZIP exportieren
                    </MudButton>

                    @if (_samples.Count > 0)
                    {
                        <div class="collection-sample-list">
                            @foreach (var sample in _samples.Take(8))
                            {
                                <div class="collection-sample-item">
                                    <span>@FormatSample(sample)</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(sample.Id))" aria-label="Rohbild loeschen" />
                                </div>
                            }
                        </div>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    [Inject] AppSettingsService AppSettings { get; set; } = default!;
    [Inject] ImageStateService ImageState { get; set; } = default!;
    [Inject] RawImageCollectionService RawImages { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    private IBrowserFile? _uploadedFile;
    private IReadOnlyList<MagicCoinSnapper.Models.RawImageSample> _samples = Array.Empty<MagicCoinSnapper.Models.RawImageSample>();
    private bool _hasImage;
    private bool _isBusy;
    private int _sampleCount;
    private string? _previewUrl;
    private string? _contentType;
    private string? _source;
    private string? _notes;
    private string _stageMessage = "Rohbild bereit";

    protected override async Task OnInitializedAsync()
    {
        AppSettings.OnChanged += OnSettingsChanged;
        RawImages.OnChanged += OnCollectionChanged;
        await AppSettings.LoadAsync();
        await RawImages.RefreshAsync();
        SyncCollectionState();
    }

    private void UseCurrentImage()
    {
        if (!ImageState.HasImage || ImageState.ImageBytes is null || string.IsNullOrWhiteSpace(ImageState.ContentType))
        {
            Snackbar.Add("Kein aktuelles Scanbild vorhanden.", Severity.Info);
            return;
        }

        _contentType = ImageState.ContentType;
        _source = ImageState.Source ?? "camera";
        _previewUrl = $"data:{ImageState.ContentType};base64,{Convert.ToBase64String(ImageState.ImageBytes)}";
        _hasImage = true;
        _stageMessage = "Scanbild uebernommen";
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null) return;

        _uploadedFile = file;
        _isBusy = true;
        try
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            _contentType = file.ContentType;
            _source = "collection-upload";
            _previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            _hasImage = true;
            _stageMessage = "Bild geladen";
        }
        catch (Exception ex) when (ex is IOException or ArgumentException)
        {
            Snackbar.Add($"Datei ungueltig oder zu gross: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SaveImageAsync()
    {
        if (!_hasImage || string.IsNullOrWhiteSpace(_previewUrl)) return;

        _isBusy = true;
        try
        {
            var metadata = new MagicCoinSnapper.Models.RawImageSampleMetadata
            {
                Source = _source ?? "collection",
                ContentType = _contentType ?? "image/png",
                Notes = _notes
            };

            var saved = await RawImages.SaveAsync(metadata, _previewUrl);
            Snackbar.Add(saved is null ? "Rohbild konnte nicht gespeichert werden." : "Rohbild gespeichert.", saved is null ? Severity.Warning : Severity.Success);
            _notes = null;
            await RawImages.RefreshAsync();
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Speichern fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ExportAsync()
    {
        _isBusy = true;
        try
        {
            var export = await RawImages.ExportAsync();
            Snackbar.Add(export is null || export.Count == 0 ? "Keine Rohbilder fuer den Export." : $"Raw-ZIP exportiert: {export.Count} Bilder.", export is null || export.Count == 0 ? Severity.Info : Severity.Success);
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Export fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteAsync(string id)
    {
        await RawImages.DeleteAsync(id);
        await RawImages.RefreshAsync();
        Snackbar.Add("Rohbild geloescht.", Severity.Success);
    }

    private static string FormatSample(MagicCoinSnapper.Models.RawImageSample sample)
    {
        var date = sample.CreatedAt.LocalDateTime.ToString("dd.MM. HH:mm");
        return string.IsNullOrWhiteSpace(sample.Notes) ? date : $"{date} · {sample.Notes}";
    }

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    private void OnCollectionChanged()
    {
        SyncCollectionState();
        InvokeAsync(StateHasChanged);
    }

    private void SyncCollectionState()
    {
        _sampleCount = RawImages.Count;
        _samples = RawImages.Samples;
    }

    public void Dispose()
    {
        AppSettings.OnChanged -= OnSettingsChanged;
        RawImages.OnChanged -= OnCollectionChanged;
    }
}
