@page "/collection"
@implements IAsyncDisposable

<PageTitle>Bildersammlung</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="collection-page">
    <MudStack Spacing="4">
        <MudStack Spacing="1" Class="collection-header">
            <h1>Bildersammlung</h1>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Bilder fuer das Desktop-Training sammeln und als ZIP exportieren.
            </MudText>
        </MudStack>

        @if (!AppSettings.ExpertModeEnabled)
        {
            <MudPaper Elevation="0" Class="collection-panel">
                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1">Expertenmodus ist aus</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Aktiviere den Expertenmodus in den Einstellungen, um Bilder fuer Trainingsdaten zu sammeln.
                    </MudText>
                    <MudButton Href="settings" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="collection-primary-button">
                        Einstellungen oeffnen
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            @* Bildansicht: Live-Kamera, aufgenommenes Bild oder Leerplatz *@
            <MudPaper Elevation="0" Class="collection-stage">
                <video id="@_videoId" class="collection-video @(_livePreview ? "" : "hidden")" playsinline autoplay muted></video>

                @if (_hasImage && !_livePreview)
                {
                    <MudImage Src="@_previewUrl" Fluid="true" ObjectFit="ObjectFit.Contain" Alt="Bild fuer Training" Class="collection-preview" />
                    <div class="collection-stage-badge">@_stageMessage</div>
                }

                @if (!_livePreview && !_hasImage)
                {
                    <div class="collection-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Collections" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">Noch kein Bild</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            Nimm ein Bild mit der Kamera auf oder lade eines aus der Galerie.
                        </MudText>
                    </div>
                }

                @if (_livePreview)
                {
                    <div class="collection-stage-badge">Hand ruhig halten. Muenze sichtbar platzieren.</div>
                }
            </MudPaper>

            @* Bildquelle: Kamera-Steuerung + Galerie-Upload (obenan, direkt unter Stage) *@
            @if (_viewingStoredId is null)
            {
                <MudPaper Elevation="0" Class="collection-panel">
                    <MudStack Spacing="3">
                        @if (_livePreview)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCapture" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.Camera">
                                Foto aufnehmen
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" OnClick="OnCameraStop" FullWidth="true">
                                Kamera stoppen
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCameraStart" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoCamera">
                                Kamera starten
                            </MudButton>
                            <MudFileUpload T="IBrowserFile" Files="_uploadedFile" FilesChanged="@((IBrowserFile? f) => OnFileSelected(f))" Accept="image/png,image/jpeg" MaxFileSize="10485760" Class="collection-upload">
                                <CustomContent Context="uploader">
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => uploader.OpenFilePickerAsync())" FullWidth="true" StartIcon="@Icons.Material.Filled.PhotoLibrary" Disabled="@_isBusy">
                                        Bild aus Galerie laden
                                    </MudButton>
                                </CustomContent>
                            </MudFileUpload>
                        }
                    </MudStack>
                </MudPaper>

                @* Notiz + Speichern + Verwerfen *@
                <MudPaper Elevation="0" Class="collection-panel">
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_notes" Label="Notiz optional" Lines="2" Variant="Variant.Outlined" Placeholder="z. B. Silberdollar, Buehnenlicht, Sharpie sichtbar" Disabled="@(!_hasImage)" />

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveImageAsync" Disabled="@(!_hasImage || _isBusy)" FullWidth="true" StartIcon="@Icons.Material.Filled.Save" Class="collection-primary-button">
                            Bild speichern
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="OnClear" Disabled="@(!_hasImage || _livePreview)" FullWidth="true" StartIcon="@Icons.Material.Filled.Delete">
                            Bild verwerfen
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                @* Anzeige-Modus fuer gespeichertes Bild *@
                <MudPaper Elevation="0" Class="collection-panel">
                    <MudStack Spacing="3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnBackToCapture" FullWidth="true" StartIcon="@Icons.Material.Filled.Camera" Class="collection-primary-button">
                            Zurück zur Aufnahme
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteStoredAsync" Disabled="@_isBusy" FullWidth="true" StartIcon="@Icons.Material.Filled.Delete">
                            Aus Speicher löschen
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }

            @* Gesammelte Bilder + Export *@
            <MudPaper Elevation="0" Class="collection-panel">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.subtitle2">Gesammelte Bilder</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_sampleCount Bilder liegen lokal im Browser. Der ZIP-Export landet im Download-/Dateien-Bereich Deines Smartphones.
                    </MudText>
                    <MudButton Variant="Variant.Outlined" OnClick="ExportAsync" Disabled="@(_sampleCount == 0 || _isBusy)" FullWidth="true" StartIcon="@Icons.Material.Filled.Archive">
                        Raw-ZIP exportieren
                    </MudButton>

                    @if (_samples.Count > 0)
                    {
                        <div class="collection-sample-list">
                            @foreach (var sample in _samples.Take(8))
                            {
                                var isActive = _viewingStoredId == sample.Id;
                                <div class="collection-sample-item @(isActive ? "is-active" : "")">
                                    <MudButton Variant="Variant.Text" FullWidth="true" OnClick="@(() => OnSampleClicked(sample))" Class="collection-sample-button">
                                        <span class="collection-sample-label">@FormatSample(sample)</span>
                                    </MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(sample.Id))" aria-label="Bild löschen" />
                                </div>
                            }
                        </div>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    [Inject] AppSettingsService AppSettings { get; set; } = default!;
    [Inject] RawImageCollectionService RawImages { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    private IBrowserFile? _uploadedFile;
    private IReadOnlyList<Models.RawImageSample> _samples = Array.Empty<Models.RawImageSample>();
    private bool _livePreview;
    private bool _isBusy;
    private bool _hasImage;
    private int _sampleCount;
    private string? _previewUrl;
    private string? _contentType;
    private string? _source;
    private string? _notes;
    private string _stageMessage = "Bild bereit";
    private string? _viewingStoredId;
    private IJSObjectReference? _module;
    private const string _videoId = "collection-cam";

    protected override async Task OnInitializedAsync()
    {
        AppSettings.OnChanged += OnSettingsChanged;
        RawImages.OnChanged += OnCollectionChanged;
        await AppSettings.LoadAsync();
        await RawImages.RefreshAsync();
        SyncCollectionState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Pages/Camera.razor.js");
        }
    }

    private async Task OnCameraStart()
    {
        if (_isBusy || _livePreview || _module is null) return;
        _isBusy = true;
        try
        {
            await _module.InvokeVoidAsync("init", _videoId);
            _livePreview = true;
        }
        catch (JSException ex)
        {
            ShowCameraError(ex);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task OnCameraStop()
    {
        await StopCameraAsync();
        _livePreview = false;
    }

    private async Task OnCapture()
    {
        if (_module is null) return;
        _isBusy = true;
        try
        {
            var dataUrl = await _module.InvokeAsync<string>("capture");
            var bytes = Convert.FromBase64String(dataUrl.Substring(dataUrl.IndexOf(',') + 1));
            SetPreview(bytes, "image/png", "camera");
            Snackbar.Add("Bild aufgenommen.", Severity.Success);
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Aufnahme fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            await StopCameraAsync();
            _livePreview = false;
            _isBusy = false;
        }
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null) return;

        _uploadedFile = file;
        _isBusy = true;
        try
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            SetPreview(ms.ToArray(), file.ContentType, "collection-upload");
            Snackbar.Add("Bild geladen.", Severity.Success);
        }
        catch (Exception ex) when (ex is IOException or ArgumentException)
        {
            Snackbar.Add($"Datei ungueltig oder zu gross: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void SetPreview(byte[] bytes, string contentType, string source)
    {
        _previewUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
        _contentType = contentType;
        _source = source;
        _hasImage = true;
        _stageMessage = source == "camera" ? "Bild aufgenommen" : "Bild geladen";
    }

    private void OnClear()
    {
        _previewUrl = null;
        _contentType = null;
        _source = null;
        _notes = null;
        _uploadedFile = null;
        _hasImage = false;
        _stageMessage = "Bild bereit";
    }

    private async Task SaveImageAsync()
    {
        if (string.IsNullOrWhiteSpace(_previewUrl)) return;

        _isBusy = true;
        try
        {
            var metadata = new Models.RawImageSampleMetadata
            {
                Source = _source ?? "collection",
                ContentType = _contentType ?? "image/png",
                Notes = _notes
            };

            var saved = await RawImages.SaveAsync(metadata, _previewUrl);
            Snackbar.Add(saved is null ? "Bild konnte nicht gespeichert werden." : "Bild gespeichert.", saved is null ? Severity.Warning : Severity.Success);
            _notes = null;
            OnClear();
            await RawImages.RefreshAsync();
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Speichern fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ExportAsync()
    {
        _isBusy = true;
        try
        {
            var export = await RawImages.ExportAsync();
            Snackbar.Add(export is null || export.Count == 0 ? "Keine Bilder fuer den Export." : $"Raw-ZIP exportiert: {export.Count} Bilder.", export is null || export.Count == 0 ? Severity.Info : Severity.Success);
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Export fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteAsync(string id)
    {
        await RawImages.DeleteAsync(id);
        await RawImages.RefreshAsync();
        if (_viewingStoredId == id)
        {
            ExitStoredView();
        }
        Snackbar.Add("Bild gelöscht.", Severity.Success);
    }

    private async Task OnSampleClicked(Models.RawImageSample sample)
    {
        if (_isBusy) return;
        _isBusy = true;
        try
        {
            await StopCameraAsync();
            _livePreview = false;

            var dataUrl = await RawImages.LoadImageDataUrlAsync(sample.Id);
            if (string.IsNullOrWhiteSpace(dataUrl))
            {
                Snackbar.Add("Bild konnte nicht geladen werden.", Severity.Warning);
                return;
            }

            _previewUrl = dataUrl;
            _contentType = sample.ContentType;
            _source = sample.Source;
            _hasImage = true;
            _viewingStoredId = sample.Id;
            _notes = sample.Notes;
            _uploadedFile = null;
            _stageMessage = FormatStoredBadge(sample);
        }
        catch (JSException ex)
        {
            Snackbar.Add($"Bild konnte nicht geladen werden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnBackToCapture()
    {
        ExitStoredView();
    }

    private async Task DeleteStoredAsync()
    {
        if (string.IsNullOrWhiteSpace(_viewingStoredId)) return;
        var id = _viewingStoredId;
        ExitStoredView();
        await RawImages.DeleteAsync(id);
        await RawImages.RefreshAsync();
        Snackbar.Add("Bild gelöscht.", Severity.Success);
    }

    private void ExitStoredView()
    {
        _viewingStoredId = null;
        _previewUrl = null;
        _contentType = null;
        _source = null;
        _notes = null;
        _uploadedFile = null;
        _hasImage = false;
        _stageMessage = "Bild bereit";
    }

    private static string FormatStoredBadge(Models.RawImageSample sample)
    {
        var date = sample.CreatedAt.LocalDateTime.ToString("dd.MM. HH:mm");
        return string.IsNullOrWhiteSpace(sample.Notes)
            ? $"Gespeichert: {date}"
            : $"Gespeichert: {date} · {sample.Notes}";
    }

    private static string FormatSample(Models.RawImageSample sample)
    {
        var date = sample.CreatedAt.LocalDateTime.ToString("dd.MM. HH:mm");
        return string.IsNullOrWhiteSpace(sample.Notes) ? date : $"{date} · {sample.Notes}";
    }

    private void ShowCameraError(JSException ex)
    {
        var msg = ex.Message;
        if (msg.Contains("NotAllowed"))
        {
            msg = "Kamerazugriff verweigert. Bitte Berechtigung pruefen.";
        }
        else if (msg.Contains("NotFound"))
        {
            msg = "Keine Kamera gefunden.";
        }
        Snackbar.Add(msg, Severity.Error);
    }

    private async Task StopCameraAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop"); }
            catch { }
        }
    }

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    private void OnCollectionChanged()
    {
        SyncCollectionState();
        InvokeAsync(StateHasChanged);
    }

    private void SyncCollectionState()
    {
        _sampleCount = RawImages.Count;
        _samples = RawImages.Samples;
    }

    public async ValueTask DisposeAsync()
    {
        AppSettings.OnChanged -= OnSettingsChanged;
        RawImages.OnChanged -= OnCollectionChanged;
        await StopCameraAsync();
        if (_module is not null)
        {
            await _module.DisposeAsync();
            _module = null;
        }
    }
}
