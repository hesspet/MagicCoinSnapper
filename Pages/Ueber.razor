@page "/ueber"
<PageTitle>Über</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mcs-page">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <h1 class="mcs-page-title">Über</h1>
            <MudText Class="mcs-lead">MagicCoinSnapper ist eine mobile PWA für Zauberer und Conjurer.</MudText>
        </MudStack>

        <MudPaper Elevation="0" Class="mcs-panel">
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle1">Zweck der App</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Die Anwendung nimmt ein Bild einer Hand mit Münze auf oder lädt ein vorhandenes Bild. Dieses Bild wird für die spätere Münzerkennung bereitgestellt.
                </MudText>
                <MudDivider />
                <MudText Typo="Typo.subtitle1">Technik</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Die App läuft clientseitig als Blazor WebAssembly PWA mit MudBlazor. Es gibt aktuell kein Backend und keine externe API.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="mcs-panel">
            <MudStack Spacing="1">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Build</MudText>
                <MudText Typo="Typo.body2">
                    Version @BuildInfo.BuildVersion
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Erstellt am @BuildInfo.BuildDate um @BuildInfo.BuildTime Uhr (Europe/Berlin)
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="mcs-panel">
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle1">Open-Source-Lizenzen</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Diese App nutzt die folgenden Open-Source-Bibliotheken. Wir danken den Maintainer:innen.
                </MudText>
                <MudStack Spacing="2">
                    <MudPaper Elevation="0" Class="mcs-panel mcs-panel-nested">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">MudBlazor · 9.5.0</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Lizenz: MIT</MudText>
                            <MudLink Href="https://github.com/MudBlazor/MudBlazor" Target="_blank" Typo="Typo.body2" Class="mcs-link-row">
                                Quelle auf GitHub
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mcs-link-icon" />
                            </MudLink>
                        </MudStack>
                    </MudPaper>
                    <MudPaper Elevation="0" Class="mcs-panel mcs-panel-nested">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Microsoft ASP.NET Core (Blazor WebAssembly) · 10.0.9</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Lizenz: MIT</MudText>
                            <MudLink Href="https://github.com/dotnet/aspnetcore" Target="_blank" Typo="Typo.body2" Class="mcs-link-row">
                                Quelle auf GitHub
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mcs-link-icon" />
                            </MudLink>
                        </MudStack>
                    </MudPaper>
                    <MudPaper Elevation="0" Class="mcs-panel mcs-panel-nested">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">ONNX Runtime Web · 1.22.0</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Lizenz: MIT</MudText>
                            <MudLink Href="https://github.com/microsoft/onnxruntime" Target="_blank" Typo="Typo.body2" Class="mcs-link-row">
                                Quelle auf GitHub
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mcs-link-icon" />
                            </MudLink>
                        </MudStack>
                    </MudPaper>
                    <MudPaper Elevation="0" Class="mcs-panel mcs-panel-nested">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">JSZip · 3.10.1</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Lizenz: MIT oder GPL-3.0-or-later</MudText>
                            <MudLink Href="https://github.com/Stuk/jszip" Target="_blank" Typo="Typo.body2" Class="mcs-link-row">
                                Quelle auf GitHub
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mcs-link-icon" />
                            </MudLink>
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>
