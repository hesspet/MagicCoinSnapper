@page "/ueber"
<PageTitle>Ueber</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mcs-page">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <h1 class="mcs-page-title">Ueber</h1>
            <MudText Class="mcs-lead">MagicCoinSnapper ist eine mobile PWA fuer Zauberer und Conjurer.</MudText>
        </MudStack>

        <MudPaper Elevation="0" Class="mcs-panel">
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle1">Zweck der App</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Die Anwendung nimmt ein Bild einer Hand mit Muenze auf oder laedt ein vorhandenes Bild. Dieses Bild wird fuer die spaetere Muenzerkennung bereitgestellt.
                </MudText>
                <MudDivider />
                <MudText Typo="Typo.subtitle1">Technik</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Die App laeuft clientseitig als Blazor WebAssembly PWA mit MudBlazor. Es gibt aktuell kein Backend und keine externe API.
                </MudText>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>
